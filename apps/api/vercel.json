{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm db:generate && pnpm turbo build --filter=@dooh/api --filter=@dooh/db --filter=@dooh/shared",
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/internal/cron/expire-holds",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/internal/cron/complete-bookings",
      "schedule": "0 * * * *"
    }
  ]
}
