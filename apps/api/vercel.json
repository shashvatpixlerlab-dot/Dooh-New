{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "cd ../.. && pnpm install --prod=false",
  "buildCommand": "cd ../.. && pnpm db:generate && pnpm turbo build --filter=@dooh/api --filter=@dooh/db --filter=@dooh/shared && cd apps/api && bash scripts/vercel-postbuild.sh",
  "builds": [
    {
      "src": "dist/vercel.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30,
        "includeFiles": [
          "dist/**",
          "node_modules/@dooh/db/dist/**",
          "node_modules/@dooh/db/src/generated/**",
          "node_modules/@dooh/shared/dist/**"
        ]
      }
    }
  ],
  "routes": [{ "src": "/(.*)", "dest": "/dist/vercel.js" }],
  "crons": [
    {
      "path": "/api/internal/cron/expire-holds",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/internal/cron/complete-bookings",
      "schedule": "0 * * * *"
    }
  ]
}
