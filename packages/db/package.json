{
  "name": "@dooh/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc && node -e \"require('node:fs').cpSync('src/generated','dist/generated',{recursive:true})\"",
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "normalize:bunny-urls": "dotenv -e ../../.env -- tsx prisma/scripts/normalize-bunny-urls.ts",
    "setup:bunny-cdn": "dotenv -e ../../.env -- tsx prisma/scripts/setup-bunny-cdn.ts",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@supabase/supabase-js": "^2.108.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@dooh/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "bcryptjs": "^2.4.3",
    "dotenv-cli": "^8.0.0",
    "jose": "^5.9.6",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
