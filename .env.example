# Copy to .env and fill in values (never commit .env)

NODE_ENV=development

# Database (local: direct :5432; Vercel API: use pooler :6543)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&sslmode=require
# VERCEL_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Supabase Auth (admin, owner, advertiser — Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_URL=https://your-project.supabase.co

# API
API_PORT=3001
PORT=3001
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
CRON_SECRET=change-me-cron-secret-min-32-chars
HOLD_TTL_MINUTES=15
DEVICE_LIVENESS_MINUTES=10
TIMEZONE=Asia/Kolkata
ALLOW_ADMIN_SIGNUP=false

# Device/TV player auth only (not Supabase Auth)
JWT_DEVICE_SECRET=change-me-device-secret-min-32-chars

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=

# Vercel deploy scripts (fill after first API deploy)
# VERCEL_API_URL=https://dooh-api-git-main-pixler-lab.vercel.app
# VERCEL_WEB_URL=https://dooh-new-web.vercel.app,https://dooh-new-web-git-main-pixler-lab.vercel.app

# Seed (creates Supabase Auth users when SUPABASE_SERVICE_ROLE_KEY is set)
ADMIN_EMAIL=admin@yopmail.com
ADMIN_PASSWORD=change-me
OWNER_EMAIL=owner@yopmail.com
OWNER_PASSWORD=change-me
ADVERTISER_EMAIL=advertiser@yopmail.com
ADVERTISER_PASSWORD=change-me

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Bunny CDN / Storage (BUNNY_CDN_HOSTNAME = pull zone host, e.g. dooh.b-cdn.net)
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_CDN_HOSTNAME=
BUNNY_API_KEY=

# Notifications (optional)
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
ADMIN_NOTIFY_PHONE=
