# Database (use Supabase pooler URL on Vercel: port 6543)
DATABASE_URL=postgresql://dooh:dooh_dev@localhost:5434/dooh?schema=public

# API
API_PORT=3001
API_URL=http://localhost:3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
CRON_SECRET=change-me-cron-secret-min-32-chars

# Auth (must match on API + web Vercel projects)
JWT_DEVICE_SECRET=change-me-device-secret-min-32-chars
JWT_ADMIN_SECRET=change-me-admin-secret-min-32-chars
JWT_OWNER_SECRET=change-me-owner-secret-min-32-chars
JWT_ADVERTISER_SECRET=change-me-advertiser-secret-min-32-chars
ALLOW_ADMIN_SIGNUP=false

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Booking / devices
HOLD_TTL_MINUTES=15
DEVICE_LIVENESS_MINUTES=5
TIMEZONE=Asia/Kolkata

# Seed (local only)
ADMIN_EMAIL=admin@yopmail.com
ADMIN_PASSWORD=Test@1233

# Razorpay (optional — mock payment without keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Bunny CDN (optional — local disk upload without keys)
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_CDN_HOSTNAME=
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=

# Notifications (optional)
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
ADMIN_NOTIFY_PHONE=
