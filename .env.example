# Copy to .env and fill in values (never commit .env)

NODE_ENV=development

# Database (local: direct :5432; Vercel API: use VERCEL_DATABASE_URL pooler :6543)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&sslmode=require
# VERCEL_DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# API
API_PORT=3001
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
CRON_SECRET=change-me-cron-secret-min-32-chars
HOLD_TTL_MINUTES=15
DEVICE_LIVENESS_MINUTES=10
TIMEZONE=Asia/Kolkata
ALLOW_ADMIN_SIGNUP=false

# JWT — must match exactly on both Vercel API + Web projects
JWT_DEVICE_SECRET=change-me-device-secret-min-32-chars
JWT_ADMIN_SECRET=change-me-admin-secret-min-32-chars
JWT_OWNER_SECRET=change-me-owner-secret-min-32-chars
JWT_ADVERTISER_SECRET=change-me-advertiser-secret-min-32-chars

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BUNNY_CDN_HOSTNAME=

# Vercel deploy scripts (fill after first API deploy)
# VERCEL_API_URL=https://dooh-api.vercel.app
# VERCEL_WEB_URL=https://dooh-web.vercel.app

# Seed (local only)
ADMIN_EMAIL=admin@yopmail.com
ADMIN_PASSWORD=change-me

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Bunny CDN / Storage
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_CDN_HOSTNAME=
BUNNY_API_KEY=

# Notifications (optional)
RESEND_API_KEY=
ADMIN_NOTIFY_EMAIL=
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
ADMIN_NOTIFY_PHONE=
